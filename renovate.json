{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "npm"
  ],
  "baseBranches": [
    "development"
  ],
  "rebaseWhen": "behind-base-branch",
  "ignorePaths": [
    "public/**",
    "Dockerfile*",
    "docker-compose.yml",
    ".nvmrc"
  ]
}
